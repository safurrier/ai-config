# Dockerfile for E2E testing with ALL supported AI coding tools
# This image provides a clean environment with all tools installed
# for comprehensive ai-config sync validation
#
# Tools installed:
# - Claude Code (@anthropic-ai/claude-code) - npm package
# - OpenAI Codex (@openai/codex) - npm package
# - OpenCode (opencode.ai) - npm package (opencode-ai)
# - Cursor CLI (cursor.com) - curl installer

FROM ubuntu:24.04

# Avoid prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    sudo \
    ca-certificates \
    python3 \
    python-is-python3 \
    python3-pip \
    python3-venv \
    unzip \
    gnupg2 \
    jq \
    tmux \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20 LTS
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ============================================
# Install AI Coding Tools (as root for global install)
# ============================================

# 1. Claude Code - npm package (well-established)
RUN npm install -g @anthropic-ai/claude-code

# 2. OpenAI Codex - npm package
RUN npm install -g @openai/codex || echo "Codex install failed - may not be published yet"

# 3. OpenCode - npm package (opencode-ai)
# Per opencode.ai docs: npm install -g opencode-ai
# Alternative: curl -fsSL https://opencode.ai/install | bash
RUN npm install -g opencode-ai || echo "OpenCode npm install failed, trying curl installer" && \
    (curl -fsSL https://opencode.ai/install | bash || echo "OpenCode install skipped")

# 4. Cursor CLI - curl installer
# Per cursor.com docs: curl https://cursor.com/install | bash
# Installs to ~/.local/bin (need to run as the user who will use it)
# We'll install as root first, then ensure PATH is set
RUN curl -fsSL https://cursor.com/install | bash || echo "Cursor install skipped - installer may not be available"

# Ensure all tool binaries are in PATH
ENV PATH="/root/.local/bin:/usr/local/bin:$PATH"

# Install uv for Python package management
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# Create testuser with sudo access
RUN useradd -m -s /bin/bash testuser \
    && echo "testuser ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Create working directory with correct permissions before switching user
RUN mkdir -p /home/testuser/ai-config && chown testuser:testuser /home/testuser/ai-config

# Switch to testuser for remaining setup
USER testuser

# Install uv for testuser
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# Install Cursor CLI for testuser (since it installs to ~/.local/bin)
RUN curl -fsSL https://cursor.com/install | bash || echo "Cursor install for testuser skipped"

# Ensure PATH includes all tool locations for testuser
ENV PATH="/home/testuser/.local/bin:/usr/local/bin:$PATH"

# Set working directory
WORKDIR /home/testuser/ai-config

# Copy the ai-config source code
COPY --chown=testuser:testuser . .

# Install ai-config and its dependencies using uv
RUN uv sync --all-extras

# ============================================
# Verify installations - capture which tools are available
# ============================================
RUN echo "=== Tool Installation Status ===" && \
    echo "Claude Code:" && (claude --version 2>&1 || echo "  NOT INSTALLED") && \
    echo "OpenAI Codex:" && (codex --version 2>&1 || echo "  NOT INSTALLED") && \
    echo "OpenCode:" && (opencode --version 2>&1 || echo "  NOT INSTALLED") && \
    echo "Cursor:" && (cursor-agent --version 2>&1 || cursor --version 2>&1 || echo "  NOT INSTALLED") && \
    echo "ai-config:" && uv run ai-config --version

# Default command: shell for interactive debugging
CMD ["/bin/bash"]
